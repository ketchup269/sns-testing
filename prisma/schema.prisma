generator client {
  provider = "prisma-client-js"
  output   = "../lib/prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String               @id @default(cuid())
  name               String?
  email              String               @unique
  password_hash      String?
  createdAt          DateTime             @default(now())
  aiUsageOption      String               @default("Normal AI Use")
  emailVerified      DateTime?
  image              String?
  accounts           Account[]
  automationEvents   AutomationEvent[]
  automationSettings AutomationSettings[]
  connectedAccounts  ConnectedAccount[]
  patternCaches      PatternCache[]
  posts              Post[]
  projects           Project[]
  projectImages      ProjectImage[]
  sessions           Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConnectedAccount {
  id                  String              @id @default(uuid())
  userId              String
  facebookUserId      String
  pageId              String
  pageAccessToken     String
  instagramBusinessId String
  longLivedUserToken  String
  tokenExpiry         DateTime
  createdAt           DateTime            @default(now())
  profilePictureUrl   String?
  username            String?
  automationEvents    AutomationEvent[]
  automationSettings  AutomationSettings?
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts               Post[]
  projects            Project[]

  @@unique([userId, pageId])
  @@index([userId])
}

model Post {
  id                 String           @id @default(cuid())
  userId             String
  connectedAccountId String
  projectId          String?
  caption            String?
  imageUrl           String
  createdAt          DateTime         @default(now())
  instagramMediaId   String?
  reach              Int              @default(0)
  saves              Int              @default(0)
  views              Int              @default(0)
  likes              Int              @default(0)
  mediaType          MediaType        @default(IMAGE)
  comments           Int              @default(0)
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  project            Project?         @relation(fields: [projectId], references: [id])
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules          Schedule[]

  @@index([userId])
  @@index([connectedAccountId])
  @@index([projectId])
}

model Project {
  id                           String            @id @default(cuid())
  userId                       String
  name                         String
  description                  String?
  defaultHashtags              String[]
  ageRange                     String?
  gender                       String?
  toneStyle                    String?
  writingStyleNotes            String?
  exampleCaptions              String?
  postingFrequency             String?
  preferredCtaTypes            String?
  toneRestrictions             String?
  campaignSpecificInstructions String?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt
  campaignDuration             String?
  customPromptNotes            String?
  location                     String?
  objective                    String?
  preferredTimeSlots           String?
  profession                   String?
  wordsToAvoid                 String?
  accountId                    String?
  patternCaches                PatternCache[]
  posts                        Post[]
  connectedAccount             ConnectedAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user                         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  images                       ProjectImage[]

  @@index([userId])
  @@index([accountId])
}

model ProjectImage {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  url         String
  storagePath String
  fileName    String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model Schedule {
  id           String         @id @default(cuid())
  postId       String
  scheduledFor DateTime
  status       ScheduleStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  post         Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status])
}

model PatternCache {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

model AutomationSettings {
  id                   String           @id @default(cuid())
  userId               String
  accountId            String           @unique
  autoDmReply          Boolean          @default(false)
  dmDelayMin           Int              @default(1)
  dmDelayMax           Int              @default(5)
  dmMode               String           @default("TEMPLATE")
  dmTemplate           String?
  dmAiPersonality      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  autoCommentReply     Boolean          @default(false)
  commentAiPersonality String?
  commentMode          String           @default("TEMPLATE")
  commentTemplate      String?
  connectedAccount     ConnectedAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AutomationEvent {
  id               String           @id @default(cuid())
  userId           String
  accountId        String
  igUserId         String
  eventType        String
  payload          String
  status           String           @default("PENDING")
  error            String?
  scheduledFor     DateTime
  processedAt      DateTime?
  createdAt        DateTime         @default(now())
  connectedAccount ConnectedAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([status])
}

enum ScheduleStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}